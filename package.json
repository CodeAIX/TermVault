{
  "name": "termvault",
  "version": "0.1.0",
  "description": "Cross-platform terminal helper app for snippet management and one-click copy",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 dist/main/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder -m",
    "dist:mac:arm64": "npm run build && electron-builder -m --arm64",
    "dist:mac:x64": "npm run build && electron-builder -m --x64",
    "dist:win": "npm run build && electron-builder -w",
    "dist:win:arm64": "npm run build && electron-builder -w --arm64",
    "dist:win:x64": "npm run build && electron-builder -w --x64",
    "dist:all": "npm run build && electron-builder -mw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeAIX/TermVault.git"
  },
  "keywords": [
    "electron",
    "terminal",
    "snippet",
    "clipboard"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/CodeAIX/TermVault/issues"
  },
  "homepage": "https://github.com/CodeAIX/TermVault#readme",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.codeix.termvault",
    "productName": "TermVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "CodeAIX",
      "repo": "TermVault"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "arch": [
        "arm64",
        "x64"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "arch": [
        "arm64",
        "x64"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
